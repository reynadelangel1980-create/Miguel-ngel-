#include <iostream>
using namespace std;

int main() {

    int A, B, C, D;

    cout << "Ingrese el primer valor: ";
    cin >> A;

    cout << "Ingrese el segundo valor: ";
    cin >> B;

    cout << "Ingrese el tercer valor: ";
    cin >> C;

    cout << "Ingrese el cuarto valor: ";
    cin >> D;

    cout << "El resultado es: ";
    cout << D << " " << C << " " << B << " " << A << endl;

    return 0;
}
